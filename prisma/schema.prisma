generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          String     @id @default(cuid())
  name        String
  contact     String?
  phone       String?
  email       String?
  salesRep    String?
  partner     String?    // 經銷商
  jiraLabel   String?    // Jira label for this customer (e.g., "客戶:ABC公司")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
  openItems   OpenItem[]
  deals       Deal[]

  @@map("customers")
}

model Activity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  source      String   // JIRA, MANUAL, MEETING, LINE, EMAIL, DOC
  title       String
  content     String?  @db.Text
  tags        String[] // PostgreSQL array
  attachments String[] // URLs
  jiraKey     String?  // Related Jira issue key
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
  @@map("activities")
}

model OpenItem {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jiraKey     String    @unique
  summary     String
  status      String
  priority    String?
  assignee    String?
  waitingOn   String?   // Customer, Sales, IT, RD, PM, Partner
  nextAction  String?
  dueDate     DateTime?
  partner     String?   // 經銷商 (from Jira custom field)
  lastReply   String?   @db.Text
  lastReplyBy String?
  lastReplyAt DateTime?
  jiraUpdated DateTime
  syncedAt    DateTime  @default(now())

  @@index([customerId])
  @@index([status])
  @@index([waitingOn])
  @@map("open_items")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Deal {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String    // 案件名稱
  type        String    @default("PURCHASE") // PURCHASE, MA, LICENSE, SUBSCRIPTION
  amount      Decimal?  @db.Decimal(12, 2) // 金額
  products    String?   // 產品項目
  salesRep    String?   // 負責業務
  closedAt    DateTime  // 成交日期
  startDate   DateTime? // 服務/保固開始日
  endDate     DateTime? // 服務/保固結束日
  autoRenew   Boolean   @default(false) // 是否自動續約
  remindDays  Int?      // 到期前提醒天數
  source      String    @default("MANUAL") // MANUAL, ODOO
  odooId      String?   // Odoo 訂單 ID (for future sync)
  notes       String?   @db.Text // 備註
  attachments String[]  // 附件 URLs
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([customerId])
  @@index([closedAt])
  @@index([endDate])
  @@map("deals")
}
